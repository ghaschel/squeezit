{
  "name": "squeezit",
  "version": "1.2.0",
  "main": "./dist/index.js",
  "type": "module",
  "bin": {
    "squeezit": "./dist/index.js",
    "sqz": "./dist/index.js"
  },
  "files": [
    "assets",
    "dist",
    "postinstall.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && bun build ./index.ts --outfile ./dist/index.js --target node",
    "prepack": "bun run build",
    "postinstall": "node ./postinstall.mjs",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "release:initial": "git fetch --tags --force && $ bunx -- commit-and-tag-version --release-as v1.0.0",
    "release": "git fetch --tags --force && commit-and-tag-version",
    "push": "git push --follow-tags",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "commit-and-tag-version": "^12.7.0",
    "cz-git": "^1.12.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "remark": "^15.0.1",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "typescript-eslint": "^8.57.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "inquirer": "^13.3.2",
    "ora": "^9.3.0"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-git"
    }
  }
}
